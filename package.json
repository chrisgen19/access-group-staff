{
	"name": "access-group-staff",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "prisma generate && prisma migrate deploy && next build",
		"start": "next start",
		"postinstall": "prisma generate",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --fix .",
		"format": "bunx @biomejs/biome format --write .",
		"db:push": "bunx prisma db push && bunx prisma db execute --file ./scripts/pre-deploy.sql",
		"db:seed": "bunx prisma db seed",
		"db:seed:showcase": "bun prisma/seed.dev-showcase.ts",
		"db:e2e:seed": "bun prisma/seed.e2e.ts",
		"db:studio": "bunx prisma studio",
		"db:reconcile-checksums": "bun scripts/reconcile-migration-checksums.ts",
		"test": "bun run test:unit",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"wt:new": "bash scripts/wt-new.sh",
		"wt:rm": "bash scripts/wt-remove.sh",
		"wt:ls": "git worktree list"
	},
	"prisma": {
		"seed": "bun prisma/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1030.0",
		"@base-ui/react": "^1.3.0",
		"@hookform/resolvers": "^5.2.2",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.95.2",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@tiptap/react": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"better-auth": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"isomorphic-dompurify": "^3.9.0",
		"lucide-react": "^1.7.0",
		"next": "16.2.1",
		"next-themes": "^0.4.6",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.72.0",
		"shadcn": "^4.1.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.3.12",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.1",
		"dotenv": "^17.3.1",
		"jsdom": "^29.0.2",
		"prisma": "^7.6.0",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.4"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
